<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         Root template. Calls gr_external_layout_standard - an isolated,
         PRIMARY inherited variant of Odoo's native Standard layout (see
         gr_external_layout.xml) - so the native .header/.article/.footer
         structure, footer text and page numbering are all preserved, while
         the header shows CLIENTE / centered logo / date+folio and repeats
         them automatically on every page. The layout is pinned to that
         variant on purpose: the company's Standard/Boxed/Bold/Striped
         picker would change the geometry this report is calibrated to.
    ================================================================= -->
    <template id="report_gr_quotation_document">
        <!-- web.report_layout (HTML preview) renders <body class="container">
             (max-width) unless full_width is truthy; keep the preview
             edge-to-edge like the PDF. -->
        <t t-set="full_width" t-value="1"/>
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-set="doc" t-value="doc.with_context(lang=doc.partner_id.lang)"/>
                <!-- o/company are normally set by web.external_layout before
                     it dispatches to a concrete layout; since we t-call the
                     concrete (inherited) layout directly, set them here. -->
                <t t-set="o" t-value="doc"/>
                <t t-set="company" t-value="doc.company_id.sudo()"/>
                <t t-call="gr_quotation_report.gr_external_layout_standard">
                    <div class="page gr_doc">
                        <!-- The style block MUST live here, inside the
                             .article: when building the PDF, Odoo extracts
                             only the article node and re-renders it inside
                             web.minimal_layout, so anything outside it
                             (like a style tag next to html_container)
                             never reaches the printed pages. -->
                        <t t-call="gr_quotation_report.gr_quotation_style"/>
                        <t t-call="gr_quotation_report.gr_quotation_client_event"/>
                        <t t-call="gr_quotation_report.gr_quotation_products"/>
                        <t t-call="gr_quotation_report.gr_quotation_summary"/>
                        <t t-call="gr_quotation_report.gr_quotation_policies"/>
                        <t t-call="gr_quotation_report.gr_quotation_signatures"/>
                    </div>
                </t>
                <t t-if="not doc_last">
                    <div style="page-break-after: always;"/>
                </t>
            </t>
        </t>
    </template>

    <!-- ================================================================
         Body styles. Everything is scoped to .gr_doc (or .gr_* classes):
         no rules on html/body/main/#wrapwrap/.article, so the native
         layout geometry and every other report stay untouched. The header
         styles its own nodes inline (see gr_external_layout.xml) because
         Odoo extracts the header into a separate wkhtmltopdf document that
         this style block does not reach.

         Measurements follow the visual reference on Letter paper with
         margins 11.5mm (left) / 13.8mm (right): useful width 190.6mm,
         panels 96.4mm + 2mm + 92.1mm, divider ~97.3mm from the page top,
         product rows ~18.8mm tall, images boxed at 16.5 x 13.6mm.
    ================================================================= -->
    <template id="gr_quotation_style">
        <style>
            @font-face {
                font-family: 'Nunito';
                src: url('/gr_quotation_report/static/src/fonts/Nunito-Regular.woff') format('woff');
                font-weight: normal; font-style: normal;
            }
            @font-face {
                font-family: 'Nunito';
                src: url('/gr_quotation_report/static/src/fonts/Nunito-Bold.woff') format('woff');
                font-weight: bold; font-style: normal;
            }
            @font-face {
                font-family: 'Nunito';
                src: url('/gr_quotation_report/static/src/fonts/Nunito-Italic.woff') format('woff');
                font-weight: normal; font-style: italic;
            }
            @font-face {
                font-family: 'Nunito';
                src: url('/gr_quotation_report/static/src/fonts/Nunito-BoldItalic.woff') format('woff');
                font-weight: bold; font-style: italic;
            }

            /* web.minimal_layout hardcodes class="container" on the PDF
               body; at a Letter-width viewport Bootstrap caps .container
               at ~540px, squeezing the content to ~75% and pinning it
               left. This rule only exists inside THIS report's article
               (the style tag travels with it into the PDF sub-document),
               so no other report is affected. */
            body.o_body_pdf {
                width: 100% !important; max-width: none !important;
                margin: 0 !important; padding: 0 !important;
            }

            .gr_doc {
                font-family: 'Nunito', Arial, Helvetica, sans-serif;
                color: #111111;
                font-size: 9.5pt;
                width: 100%;
                line-height: 1.35;
            }
            /* The document-layout table skins (o_table_standard etc.) are
               opted out per-table via o_ignore_layout_styling; the ::before
               outer frame some skins draw is neutralized here, scoped to
               this report's tables only. */
            .gr_doc table::before { content: none !important; border: none !important; }
            .gr_doc table { border-collapse: collapse; }
            .gr_doc td, .gr_doc th { vertical-align: top; }

            /* Black rules (0.25mm). gr_hr_top opens the general-information
               block right where the body starts; gr_hr_thin closes it. The
               cards span the full useful width, so their outer edges stay
               aligned with both rules and the whole block reads as one
               unit. */
            .gr_hr_top { height: 0.25mm; background-color: #111111; margin: 0 0 2.2mm 0; }
            .gr_hr_thin { height: 0.25mm; background-color: #111111; margin: 2.4mm 0 0 0; }
            .gr_hr_thick { height: 0.25mm; background-color: #111111; margin: 4mm 0 4mm 0; }

            /* ---- general information (client / event cards) ----
               Two near-symmetric columns (96.4mm + 2mm + 92.1mm over the
               190.6mm useful width): one tall card on the left (warm beige
               background), two stacked white cards on the right. Flat 1px
               light-gray borders, square corners, compact padding. Heights
               are minimums: the label/value pairs keep their slot even
               when a field is empty. */
            .gr_info_table { width: 100%; table-layout: fixed; }
            .gr_info_left {
                width: 96.4mm;
                background-color: #F2EEEC; border: 1px solid #CCCCCC;
                padding: 2.8mm; vertical-align: top; overflow-wrap: break-word;
            }
            .gr_info_spacer { width: 2mm; }
            .gr_info_right { width: 92.1mm; vertical-align: top; padding: 0; }
            .gr_box_white {
                min-height: 24mm; background-color: #ffffff;
                border: 1px solid #CCCCCC; padding: 2.8mm;
            }
            .gr_box_venue { min-height: 22mm; margin-top: 1.6mm; }
            .gr_subgrid { width: 100%; table-layout: fixed; margin-top: 1.2mm; }
            .gr_half { width: 50%; vertical-align: top; overflow-wrap: break-word; padding-right: 2mm; }
            /* Two-level hierarchy: small uppercase regular labels
               (~12.5px), much larger bold-italic values (~20.5px), tight
               leading so the block stays compact. */
            .gr_label {
                display: block; font-size: 9.4pt; font-weight: normal;
                text-transform: uppercase; color: #111111;
                line-height: 1.1; margin-bottom: 0.4mm;
            }
            .gr_value {
                display: block; font-size: 15.4pt; font-weight: bold; font-style: italic;
                color: #111111; line-height: 1.05; min-height: 5.8mm;
                margin-bottom: 1.6mm;
            }
            .gr_value_block { white-space: pre-line; }

            /* ---- products table ----
               Starts ~12.9mm below the divider; heads underline the text
               only (no full-width cell border); rows ~18.8mm tall. */
            .gr_products_table { width: 100%; table-layout: fixed; margin-top: 12.9mm; }
            .gr_products_table thead th {
                font-size: 10.5pt; font-weight: bold; color: #111111;
                text-decoration: underline; text-align: left;
                padding-bottom: 1.5mm;
            }
            .gr_th_center { text-align: center !important; }
            .gr_th_right { text-align: right !important; }
            .gr_products_table tbody td {
                height: 18.8mm; padding: 1.2mm 1mm;
                font-size: 9pt; line-height: 1.25;
            }
            .gr_row_product { page-break-inside: avoid; }
            .gr_td_center { text-align: center; }
            .gr_td_right { text-align: right; }
            .gr_product_img { max-width: 16.5mm; max-height: 13.6mm; }
            .gr_img_placeholder {
                width: 16.5mm; height: 13.6mm; margin: 0 auto;
                border: 0.2mm solid #111111; background-color: #FAFAF8;
            }
            .gr_article_title { font-size: 9pt; font-weight: normal; }
            .gr_article_extra {
                font-size: 8.5pt; color: #333333; margin-top: 1mm; white-space: pre-line;
            }
            .gr_row_section td {
                font-weight: bold; text-transform: uppercase; font-size: 9.5pt;
                border-top: 0.2mm solid #C9C9C9; padding-top: 3.5mm !important;
                height: auto !important;
            }
            .gr_row_note td { font-style: italic; color: #333333; height: auto !important; }

            /* ---- summary ---- */
            .gr_summary_wrap { width: 100%; table-layout: fixed; margin-top: 4mm; page-break-inside: avoid; }
            .gr_summary_spacer { width: 55%; }
            .gr_summary_col { width: 45%; vertical-align: top; }
            .gr_summary_table { width: 100%; }
            .gr_summary_table td { padding: 1.1mm 0; font-size: 9pt; }
            .gr_summary_label { text-align: right; font-style: italic; padding-right: 3mm !important; white-space: nowrap; }
            .gr_summary_value { text-align: right; white-space: nowrap; }
            .gr_summary_strong td { font-weight: bold; font-style: italic; }

            /* ---- policies ---- */
            .gr_policies_wrap { margin-top: 2mm; }
            .gr_policies_title {
                font-weight: bold; text-transform: uppercase; text-decoration: underline;
                font-size: 10pt; margin-bottom: 2.5mm;
            }
            .gr_policy_list {
                font-size: 8.7pt; line-height: 1.22; margin: 0; padding-left: 5mm;
                text-align: justify;
            }
            .gr_policy_list li { margin-bottom: 1.6mm; padding-left: 1mm; }
            .gr_policy_list ul { margin: 1mm 0 1mm 4mm; padding-left: 3mm; list-style: disc; }

            /* ---- signatures ---- */
            .gr_sign_wrap { width: 100%; table-layout: fixed; margin-top: 9mm; page-break-inside: avoid; }
            .gr_sign_cell { width: 45%; text-align: center; vertical-align: bottom; }
            .gr_sign_gap { width: 10%; }
            .gr_sign_line { border-top: 0.25mm solid #111111; margin-top: 18mm; }
            .gr_sign_title {
                font-weight: bold; text-transform: uppercase; font-size: 9pt;
                margin-top: 1.5mm;
            }
            .gr_sign_legend { font-size: 6.8pt; color: #333333; margin-top: 1mm; }
        </style>
    </template>

    <!-- ================================================================
         Client contact + event + assembly/disassembly panels.
    ================================================================= -->
    <template id="gr_quotation_client_event">
        <t t-set="contracting" t-value="doc._gr_get_contracting_partner()"/>
        <div class="gr_hr_top"/>
        <table class="gr_info_table o_ignore_layout_styling">
            <tr>
                <td class="gr_info_left">
                    <div class="gr_label">CONTRATANTE:</div>
                    <div class="gr_value" t-esc="contracting.name or ''"/>
                    <div class="gr_label">TELÉFONO/CELULAR:</div>
                    <div class="gr_value" t-esc="doc._gr_get_contact_phone()"/>
                    <div class="gr_label">CORREO:</div>
                    <div class="gr_value" t-esc="doc._gr_get_contact_email()"/>
                    <div class="gr_label">COORDINACIÓN/WEDDING PLANNER:</div>
                    <div class="gr_value" t-esc="doc.x_event_coordinator or ''"/>
                    <div class="gr_label">TIPO DE EVENTO:</div>
                    <div class="gr_value" style="margin-bottom: 0;" t-esc="doc.x_event_type_id.name or ''"/>
                </td>
                <td class="gr_info_spacer"/>
                <td class="gr_info_right">
                    <div class="gr_box_white">
                        <div class="gr_label">FECHA DE EVENTO:</div>
                        <div class="gr_value" t-esc="doc._gr_format_date(doc.x_event_start)"/>
                        <table class="gr_subgrid o_ignore_layout_styling">
                            <tr>
                                <td class="gr_half">
                                    <div class="gr_label">FECHA DE MONTAJE:</div>
                                    <div class="gr_value" style="margin-bottom: 0;" t-esc="doc._gr_format_date(doc.x_block_start)"/>
                                </td>
                                <td class="gr_half">
                                    <div class="gr_label">FECHA DE DESMONTAJE:</div>
                                    <div class="gr_value" style="margin-bottom: 0;" t-esc="doc._gr_format_date(doc.x_block_end)"/>
                                </td>
                            </tr>
                        </table>
                    </div>
                    <div class="gr_box_white gr_box_venue">
                        <div class="gr_label">DIRECCIÓN DEL MONTAJE:</div>
                        <div class="gr_value gr_value_block" t-esc="doc.x_event_location or ''"/>
                        <div class="gr_label">TELÉFONO DE CONTACTO ADICIONAL:</div>
                        <div class="gr_value" style="margin-bottom: 0;" t-esc="doc.x_additional_contact_phone or ''"/>
                    </div>
                </td>
            </tr>
        </table>
        <div class="gr_hr_thin"/>
    </template>

    <!-- ================================================================
         Products table. Any number of lines; sections/subsections/notes
         render as a full-width row; down payments are not shown as
         furniture. Column heads repeat on page breaks (thead).
    ================================================================= -->
    <template id="gr_quotation_products">
        <table class="gr_products_table o_ignore_layout_styling">
            <colgroup>
                <col style="width:7.4%"/>
                <col style="width:13.6%"/>
                <col style="width:25.9%"/>
                <col style="width:14.5%"/>
                <col style="width:11.6%"/>
                <col style="width:15%"/>
                <col style="width:12%"/>
            </colgroup>
            <thead>
                <tr>
                    <th class="gr_th_center">CANT.</th>
                    <th/>
                    <th>ARTÍCULO</th>
                    <th class="gr_th_center">DURACIÓN</th>
                    <th class="gr_th_right">PRECIO</th>
                    <th class="gr_th_center">IMPUESTO</th>
                    <th class="gr_th_right">TOTAL</th>
                </tr>
            </thead>
            <tbody>
                <t t-foreach="doc.order_line" t-as="line">
                    <t t-if="line.display_type in ('line_section', 'line_subsection')">
                        <tr class="gr_row_section"><td colspan="7" t-esc="line.name"/></tr>
                    </t>
                    <t t-elif="line.display_type == 'line_note'">
                        <tr class="gr_row_note"><td colspan="7" t-esc="line.name"/></tr>
                    </t>
                    <t t-elif="not line.is_downpayment">
                        <tr class="gr_row_product">
                            <td class="gr_td_center" t-esc="line.x_gr_qty_label"/>
                            <td class="gr_td_center">
                                <t t-if="line.product_id.image_128">
                                    <img t-att-src="image_data_uri(line.product_id.image_128)" class="gr_product_img"/>
                                </t>
                                <t t-else="">
                                    <div class="gr_img_placeholder"/>
                                </t>
                            </td>
                            <td>
                                <div class="gr_article_title" t-esc="line.x_gr_article_title"/>
                                <div t-if="line.x_gr_article_extra" class="gr_article_extra" t-esc="line.x_gr_article_extra"/>
                            </td>
                            <td class="gr_td_center" t-esc="line.x_gr_duration_label"/>
                            <td class="gr_td_right">
                                <span t-field="line.x_gr_price_after_discount"
                                      t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                            </td>
                            <td class="gr_td_center" t-esc="line.x_gr_tax_label"/>
                            <td class="gr_td_right">
                                <span t-field="line.price_total"
                                      t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                            </td>
                        </tr>
                    </t>
                </t>
            </tbody>
        </table>
    </template>

    <!-- ================================================================
         Economic summary: subtotal, discounts, tax, paid, overpayment.
    ================================================================= -->
    <template id="gr_quotation_summary">
        <table class="gr_summary_wrap o_ignore_layout_styling">
            <tr>
                <td class="gr_summary_spacer"/>
                <td class="gr_summary_col">
                    <table class="gr_summary_table o_ignore_layout_styling">
                        <tr>
                            <td class="gr_summary_label">SUBTOTAL</td>
                            <td class="gr_summary_value">
                                <span t-field="doc.x_amount_gross_subtotal" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                            </td>
                        </tr>
                        <tr>
                            <td class="gr_summary_label">DESCUENTOS:</td>
                            <td class="gr_summary_value">
                                <span t-field="doc.x_amount_discount_total" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                            </td>
                        </tr>
                        <tr class="gr_summary_strong">
                            <td class="gr_summary_label">TOTAL:</td>
                            <td class="gr_summary_value">
                                <span t-field="doc.amount_untaxed" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                            </td>
                        </tr>
                        <tr>
                            <td class="gr_summary_label">I.V.A</td>
                            <td class="gr_summary_value">
                                <span t-field="doc.amount_tax" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                            </td>
                        </tr>
                        <tr class="gr_summary_strong">
                            <td class="gr_summary_label">TOTAL INCL. I.V.A.</td>
                            <td class="gr_summary_value">
                                <span t-field="doc.amount_total" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                            </td>
                        </tr>
                        <tr>
                            <td class="gr_summary_label">PAGADO</td>
                            <td class="gr_summary_value">
                                <span t-field="doc.x_amount_paid" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                            </td>
                        </tr>
                        <tr class="gr_summary_strong">
                            <td class="gr_summary_label">EXCEDENTE</td>
                            <td class="gr_summary_value">
                                <span t-field="doc.x_amount_overpaid" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>
        <div class="gr_hr_thick"/>
    </template>

    <!-- ================================================================
         Policies: configurable via gr.quotation.policy, frozen on confirm.
    ================================================================= -->
    <template id="gr_quotation_policies">
        <div class="gr_policies_wrap">
            <div class="gr_policies_title">Políticas</div>
            <t t-out="doc._gr_get_policies_html()"/>
        </div>
    </template>

    <!-- ================================================================
         Physical signature spaces (no signature image is invented here).
    ================================================================= -->
    <template id="gr_quotation_signatures">
        <table class="gr_sign_wrap o_ignore_layout_styling">
            <tr>
                <td class="gr_sign_cell">
                    <div class="gr_sign_line"/>
                    <div class="gr_sign_title">Enterado</div>
                    <div class="gr_sign_legend">*Confirmo que leí y acepto las políticas y términos de esta cotización</div>
                </td>
                <td class="gr_sign_gap"/>
                <td class="gr_sign_cell">
                    <div class="gr_sign_line"/>
                    <div class="gr_sign_title">Entregado</div>
                    <div class="gr_sign_legend">*Confirmo que el equipo de Getting Ready entregó y colocó el mobiliario en buenas condiciones</div>
                </td>
            </tr>
        </table>
    </template>

</odoo>
