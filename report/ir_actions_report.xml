<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Per explicit client instruction: do NOT add a second, competing
         report action for sale.order. Instead, personalize the standard
         "Quotation / Order" action in place, so every entry point that
         already uses it - the Print button, "Send by email", the chatter
         preview, the portal PDF link - renders the GR design automatically,
         with no extra action to bind/unbind and no mail template to touch. -->
    <record id="sale.action_report_saleorder" model="ir.actions.report">
        <field name="name">Cotización Getting Ready</field>
        <field name="report_name">gr_quotation_report.report_gr_quotation_document</field>
        <field name="report_file">gr_quotation_report.report_gr_quotation_document</field>
        <field name="print_report_name">object._gr_report_filename()</field>
        <field name="paperformat_id" ref="gr_quotation_report.paperformat_gr_quotation"/>
    </record>
</odoo>
