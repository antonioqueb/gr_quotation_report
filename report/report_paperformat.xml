<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Letter/vertical paper format calibrated to the visual reference.

         wkhtmltopdf geometry: body content starts at margin_top from the
         physical page top on EVERY page; the native header is anchored so
         its bottom edge sits at (margin_top - header_spacing), growing
         upward from there.
           margin_top      = 49.6mm  (body start)
           header_spacing  = 46mm    (each extra mm of spacing raises the
                                      rendered band ~1mm on this server,
                                      per the visual iterations; +4mm
                                      requested on top of the previous 42)
           header height   = 28mm    (fixed in gr_external_layout.xml;
                                      grown slightly so the logo can reach
                                      27mm while the band stays compact)

         dpi MUST stay at 96: Odoo passes a zoom of 96/dpi to wkhtmltopdf
         (>= 0.12.2), so any other dpi rescales every CSS mm/pt in the
         document - at the previous dpi=150 everything rendered at 64% of
         its physical size, which is why the header kept sitting ~12mm
         lower than calculated (it is anchored bottom-up, so a shrunken
         header drops its top edge) and the whole body looked compressed.
         With dpi=96 the zoom is exactly 1.0 and CSS mm = physical mm.
         Never compensate with negative margins: this single set of page
         properties applies identically to page 1 and every later page.

         format='Letter' fixes the page to 215.9 x 279.4mm; page_width/
         page_height must stay empty (report.paperformat forbids combining
         a named format with a custom size - see _check_format_or_page). -->
    <record id="paperformat_gr_quotation" model="report.paperformat">
        <field name="name">Getting Ready - Cotización (Carta)</field>
        <field name="default" eval="False"/>
        <field name="format">Letter</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">49.6</field>
        <field name="margin_bottom">18</field>
        <field name="margin_left">11.5</field>
        <field name="margin_right">13.8</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">46</field>
        <field name="dpi">96</field>
        <field name="disable_shrinking" eval="True"/>
    </record>
</odoo>
