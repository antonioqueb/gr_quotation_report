<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Explicit client request: "Cotización Getting Ready" must be THE
         report used by Print, by "Send by email" and by the email preview
         on sale.order — not an extra option in a dropdown next to the
         generic Odoo one. We don't delete the standard report (still usable
         by xmlid/reference elsewhere); we only unbind it from sale.order so
         it stops competing in the Print menu, and repoint the quotation /
         confirmation mail templates to our report. -->

    <record id="sale.action_report_saleorder" model="ir.actions.report">
        <field name="binding_model_id" eval="False"/>
    </record>

    <record id="sale.email_template_edi_sale" model="mail.template">
        <field name="report_template_ids" eval="[(6, 0, [ref('gr_quotation_report.action_report_gr_quotation')])]"/>
    </record>

    <record id="sale.mail_template_sale_confirmation" model="mail.template">
        <field name="report_template_ids" eval="[(6, 0, [ref('gr_quotation_report.action_report_gr_quotation')])]"/>
    </record>
</odoo>
