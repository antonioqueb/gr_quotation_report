<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_gr_quotation_policy_list" model="ir.ui.view">
        <field name="name">gr.quotation.policy.list</field>
        <field name="model">gr.quotation.policy</field>
        <field name="arch" type="xml">
            <list string="Políticas de cotización" default_order="sequence">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="active" widget="boolean_toggle"/>
                <field name="company_id" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_gr_quotation_policy_form" model="ir.ui.view">
        <field name="name">gr.quotation.policy.form</field>
        <field name="model">gr.quotation.policy</field>
        <field name="arch" type="xml">
            <form string="Política de cotización">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Ej. Política de descuento por set adicional"/></h1>
                    </div>
                    <group>
                        <field name="sequence"/>
                        <field name="active"/>
                        <field name="company_id"/>
                    </group>
                    <group string="Texto tal como aparece numerado en el PDF">
                        <field name="content" nolabel="1" placeholder="Texto de la política. Puede incluir una sublista con viñetas."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_gr_quotation_policy" model="ir.actions.act_window">
        <field name="name">Políticas de cotización (Getting Ready)</field>
        <field name="res_model">gr.quotation.policy</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea la primera política comercial de la cotización Getting Ready.
            </p>
            <p>
                Estas políticas se numeran e imprimen, en el orden indicado, en la
                sección "POLÍTICAS" de la Cotización Getting Ready. Al confirmar
                una cotización se congela una copia de las políticas vigentes en
                ese momento, para que cambios futuros no alteren documentos
                históricos.
            </p>
        </field>
    </record>

    <menuitem id="menu_gr_quotation_policy"
              name="Políticas de cotización GR"
              parent="sale.menu_sale_config"
              action="action_gr_quotation_policy"
              sequence="60"/>
</odoo>
